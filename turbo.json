{
	"$schema": "https://turbo.build/schema.json",
	"globalPassThroughEnv": ["LAUNCH_EDITOR"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [
				".svelte-kit/**",
				"dist/**",
				".build/**",
				".vercel/**",
				"build/**"
			]
		},
		"lint": {
			"cache": false,
			"inputs": ["**/*.{ts,tsx,js,jsx,svelte,md,json}"]
		},
		"typecheck": {
			"cache": false,
			"inputs": ["**/*.{ts,tsx,js,jsx,svelte,md,json}"]
		},
		"test": {
			"cache": false,
			"inputs": ["**/*.{ts,tsx,js,jsx,svelte,json}"]
		},
		"bench": {
			"cache": false,
			"inputs": ["**/*.bench.ts"]
		},
		"format": {
			"cache": false,
			"inputs": ["**/*.{ts,tsx,js,jsx,svelte,md,json}"]
		},
		"format:check": {
			"cache": false,
			"inputs": ["**/*.{ts,tsx,js,jsx,svelte,md,json}"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
