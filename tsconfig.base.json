{
	"compilerOptions": {
		// Language
		"target": "ESNext",
		"lib": ["ESNext"],
		"moduleDetection": "force",
		// Disable auto-include of every package under node_modules/@types.
		// Each package opts in explicitly via `"types": ["bun"]` or `["node"]`.
		"types": [],

		// Modules: every package is source-only .ts consumed by Bun or a
		// bundler. `module: preserve` implies `moduleResolution: bundler`;
		// the pair is kept explicit for readability.
		"module": "preserve",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,

		// JavaScript Support
		"allowJs": true,

		// Emit: type-check only; Bun and bundlers handle transpilation.
		"noEmit": true,

		// Interop
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"esModuleInterop": true,

		// Type Checking
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		// Completeness
		"skipLibCheck": true
	}
}
